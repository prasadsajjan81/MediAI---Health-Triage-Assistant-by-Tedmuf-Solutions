rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches Auth UID)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - role: string (admin, user)
    //   - subscriptionStatus: string (free, active, expired)
    //   - subscriptionEndDate: timestamp
    //   - freeTestsRemaining: int
    //   - createdAt: timestamp
    //
    // Collection: analyses
    // Document ID: {analysisId}
    // Fields:
    //   - userId: string (required)
    //   - markdown: string (required)
    //   - triageLevel: string
    //   - summaryQuick: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "prasadsajjan81@gmail.com" && request.auth.token.email_verified == true));
    }

    function isProfessionalOrStudent() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['doctor', 'hospital', 'student', 'admin'];
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user', 'doctor', 'hospital', 'student'];
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'markdown', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.markdown is string &&
             data.markdown.size() < 100000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) && 
                    (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin()) && isValidUser(request.resource.data) &&
                    (isAdmin() || request.resource.data.role == resource.data.role || request.resource.data.role in ['student', 'doctor', 'hospital']);
      allow delete: if isAdmin();
    }

    match /analyses/{analysisId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isProfessionalOrStudent());
      allow create: if isAuthenticated() && isValidAnalysis(request.resource.data);
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }
  }
}
